{
  "name": "@pokemon/cli",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "pokemon": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/cli.mjs",
    "dev": "node build.mjs && cross-env DEBUG=1 node dist/cli.mjs",
    "watch": "nodemon --watch src --watch ../battle/src --watch ../i18n/src -e js,jsx --exec \"pnpm run build && cross-env DEBUG=1 node dist/cli.mjs\""
  },
  "dependencies": {
    "@pkmn/data": "^0.10.7",
    "@pkmn/dex": "^0.10.7",
    "@pokemon/core": "workspace:*",
    "@smogon/calc": "^0.11.0",
    "ink": "^4.4.1",
    "ink-select-input": "^5.0.0",
    "jimp": "^1.6.0",
    "keypress": "^0.2.1",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "esbuild": "^0.20.0",
    "nodemon": "^3.1.0"
  }
}
